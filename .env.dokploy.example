APP_URL=https://cv.umhl.dev
PRINTER_APP_URL=http://app:3000
PRINTER_ENDPOINT=ws://printer:3000?token=<your PRINTER_TOKEN value>
PRINTER_TOKEN=<your PRINTER_TOKEN value>
AUTH_SECRET=<your AUTH_SECRET value>
DB_PASSWORD=<your DB_PASSWORD value>
S3_ACCESS_KEY_ID=<R2 access key — same as in um-homelab .env>
S3_SECRET_ACCESS_KEY=<R2 secret key — same as in um-homelab .env>
S3_REGION=auto
S3_ENDPOINT=<R2 endpoint — same as in um-homelab .env>
S3_BUCKET=rxresume-custom
S3_FORCE_PATH_STYLE=false
FLAG_DISABLE_SIGNUPS=true
